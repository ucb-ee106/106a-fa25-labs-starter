<launch>
  <!-- Frames of reference -->
  <arg name="fixed_frame" default="odom"/>
  <arg name="sensor_frame" default="base_link"/>
  <!-- Topics -->
  <arg name="sensor_topic" default="/scan"/>
  <arg name="vis_topic" default="/vis/map"/>
  <!-- Dimensions and bounds -->
  <arg name="x_num_arg" default="25"/>
  <arg name="x_min_arg" default="-10.0"/>
  <arg name="x_max_arg" default="10.0"/>
  <arg name="y_num_arg" default="25"/>
  <arg name="y_min_arg" default="-10.0"/>
  <arg name="y_max_arg" default="10.0"/>
  <!-- Update parameters -->
  <arg name="occupied_update" default="0.7"/>
  <arg name="occupied_threshold" default="0.97"/>
  <arg name="free_update" default="0.3"/>
  <arg name="free_threshold" default="0.03"/>
  <!-- Random downsample -->
  <arg name="random_downsample" default="0.1"/>
  <!-- Mapper node -->
  <node pkg="mapping"
        exec="mapping_node"
        name="mapper"
        output="screen"> 
    <param name="frames/fixed" value="$(var fixed_frame)"/>
    <param name="frames/sensor" value="$(var sensor_frame)"/>
    <param name="topics/vis" value="$(var vis_topic)"/>
    <param name="topics/sensor" value="$(var sensor_topic)"/>
    <param name="x_num_param" value="$(var x_num_arg)"/>
    <param name="x_min_param" value="$(var x_min_arg)"/>
    <param name="x_max_param" value="$(var x_max_arg)"/>
    <param name="y_num_param" value="$(var y_num_arg)"/>
    <param name="y_min_param" value="$(var y_min_arg)"/>
    <param name="y_max_param" value="$(var y_max_arg)"/>
    <param name="update/occupied" value="$(var occupied_update)"/>
    <param name="update/occupied_threshold" value="$(var occupied_threshold)"/>
    <param name="update/free" value="$(var free_update)"/>
    <param name="update/free_threshold" value="$(var free_threshold)"/>
    <param name="random_downsample" value="$(var random_downsample)"/>
  </node>
</launch>
